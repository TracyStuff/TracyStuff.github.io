---
import { Image } from 'astro:assets';
import type { MediaItem } from '../../lib/data';

interface Props {
	id: string;
	media: MediaItem[];
	title?: string;
	caption?: string;
}

const { id, media, title, caption } = Astro.props;
const images = media ?? [];
---

<div 
	class="lightbox" 
	data-lightbox={id} 
	aria-hidden="true"
>
	<div class="lightbox-backdrop"></div>
	
	<div class="lightbox-content">
		<button class="lightbox-close" aria-label="Close">×</button>
		<button class="lightbox-prev" aria-label="Previous gallery item">‹</button>

		<div class="lightbox-image-wrap">
			{title && <div class="lightbox-title">{title}</div>}
			
			<div class="lightbox-stage">
				<img class="lightbox-image" alt="" />
			</div>
			
			{caption && <div class="lightbox-caption-text">{caption}</div>}
		</div>

		<button class="lightbox-next" aria-label="Next gallery item">›</button>

		<div class="lightbox-caption-bar">
			<span class="lightbox-counter"></span>
		</div>

		<div class="lightbox-thumbnails">
			{images.map((image, index) => (
				<button class="lightbox-thumb" data-index={index} aria-label={`Show image ${index + 1}`}>
					<Image
						src={image.src}
						alt={image.alt ?? ''}
						width={100}
						height={100}
						format="webp"
						quality={60}
					/>
				</button>
			))}
		</div>
	</div>
</div>

<style>
.lightbox {
	position: fixed;
	inset: 0;
	z-index: 9999;
	display: none;
	align-items: center;
	justify-content: center;
}
.lightbox.open { display: flex; }
.lightbox-backdrop {
	position: absolute;
	inset: 0;
	background: rgba(0,0,0,.96);
}
.lightbox-content {
	position: relative;
	z-index: 1;
	width: 100%;
	height: 100%;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
}
.lightbox-image-wrap {
	width: 100%;
	height: 65vh;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	overflow: hidden;
}
.lightbox-title {
	text-align: center;
	margin-bottom: 15px;
	color: #ffffff;
	font-family: sans-serif;
	font-size: 20px;
	font-weight: 500;
	text-shadow: 0 2px 5px rgba(0,0,0,0.8);
}
.lightbox-stage {
	width: 100%;
	height: 100%;
	display: flex;
	align-items: center;
	justify-content: center;
	will-change: transform, opacity;
}
.lightbox-stage.animate-physics {
	transition: transform 0.35s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.25s ease-in-out;
}
.lightbox-image {
	max-width: 95%;
	max-height: 100%;
	object-fit: contain;
	border: 3px solid #fff;
	box-shadow: 0 0 25px rgba(0,0,0,0.9);
	user-select: none;
	-webkit-user-drag: none;
	touch-action: none !important; 
}
.lightbox-caption-text {
	color: #bbb;
	font-size: 14px;
	margin-top: 15px;
}
.lightbox-close {
	position: absolute;
	right: 30px;
	top: 20px;
	font-size: 40px;
	color: white;
	background: none;
	border: 0;
	cursor: pointer;
	z-index: 10000;
}
.lightbox-prev, .lightbox-next {
	position: absolute;
	top: 50%;
	transform: translateY(-50%);
	font-size: 40px;
	background: rgba(255,255,255,0.1);
	border: 0;
	color: white;
	cursor: pointer;
	padding: 5px 15px;
	border-radius: 5px;
	z-index: 10000;
}
.lightbox-prev { left: 30px; }
.lightbox-next { right: 30px; }
.lightbox-caption-bar {
	margin-top: 25px;
	color: white;
}
.lightbox-thumbnails {
	display: flex;
	gap: 8px;
	margin-top: 15px;
	max-width: 800px;
	padding: 0 20px;
	overflow-x: auto;
}
.lightbox-thumb {
	padding: 0;
	border: 2px solid transparent;
	background: none;
	cursor: pointer;
	opacity: 0.5;
	transition: all 0.2s;
}
.lightbox-thumb.active {
	border-color: #159957;
	opacity: 1;
}
.lightbox-thumb img {
	width: 75px;
	height: 75px;
	object-fit: cover;
	border-radius: 4px;
}
</style>

<script>
	const lightboxes = Array.from(document.querySelectorAll('[data-lightbox]'));

	lightboxes.forEach((rootEl, currentBlockIndex) => {
		const root = rootEl as HTMLElement;
		if (root.dataset.initialized) return;
		root.dataset.initialized = 'true';

		const id = root.dataset.lightbox;
		const stage = root.querySelector('.lightbox-stage') as HTMLElement;
		const img = root.querySelector('.lightbox-image') as HTMLImageElement;
		const counter = root.querySelector('.lightbox-counter');
		const thumbs = Array.from(root.querySelectorAll('.lightbox-thumb')) as HTMLElement[];
		const close = root.querySelector('.lightbox-close');
		const prevBtn = root.querySelector('.lightbox-prev');
		const nextBtn = root.querySelector('.lightbox-next');

		const clientImages = thumbs.map((thumb) => {
			const thumbImg = thumb.querySelector('img');
			return {
				src: thumbImg ? thumbImg.src : '',
				alt: thumbImg ? thumbImg.alt : ''
			};
		});

		let index = 0; // Tracks active image inside THIS lightbox item
		let pointerActive = false;
		let startX = 0;
		let deltaX = 0;

		// DOM-derived neighbor lookups for clean decoupling
		const navigateToBlock = (direction: 'next' | 'prev') => {
			let targetIndex = direction === 'next' ? currentBlockIndex + 1 : currentBlockIndex - 1;
			
			// Continuous wrapping across all cards on the page layout
			if (targetIndex >= lightboxes.length) targetIndex = 0;
			if (targetIndex < 0) targetIndex = lightboxes.length - 1;

			const targetLightbox = lightboxes[targetIndex] as HTMLElement;
			if (!targetLightbox) return;

			hide(); // Close this module

			// Trigger the custom event bridge to open our layout neighbor instantly
			window.dispatchEvent(
				new CustomEvent('open-lightbox', {
					detail: {
						id: targetLightbox.dataset.lightbox,
						index: 0 // Reset to showing the first asset of the next item
					}
				})
			);
		};

		const showImage = (newIndex: number) => {
			if (clientImages.length === 0 || !stage || !img) return;

			index = (newIndex + clientImages.length) % clientImages.length;
			const item = clientImages[index];

			stage.classList.remove('animate-physics');
			stage.style.opacity = '0';
			img.src = item.src;
			img.alt = item.alt;
			
			setTimeout(() => {
				stage.classList.add('animate-physics');
				stage.style.opacity = '1';
			}, 50);

			if (counter) counter.textContent = `${index + 1} / ${clientImages.length}`;
			thumbs.forEach((thumb, i) => thumb.classList.toggle('active', i === index));
		};

		// Left & Right navigation triggers now target adjacent items instead of adjacent images
		prevBtn?.addEventListener('click', () => navigateToBlock('prev'));
		nextBtn?.addEventListener('click', () => navigateToBlock('next'));
		close?.addEventListener('click', hide);
		root.querySelector('.lightbox-backdrop')?.addEventListener('click', hide);

		// HIGH-PERFORMANCE INTERACTIVE DRAG SWIPE ENGINE
		root.addEventListener('pointerdown', (e: PointerEvent) => {
			if ((e.target as HTMLElement).closest('button') || !stage) return;
			pointerActive = true;
			startX = e.clientX;
			deltaX = 0;
			stage.classList.remove('animate-physics');
		});

		window.addEventListener('pointermove', (e: PointerEvent) => {
			if (!pointerActive || !stage) return;
			deltaX = e.clientX - startX;

			// Fluidly move stage canvas matching layout gestures
			stage.style.transform = `translate3d(${deltaX}px, 0, 0)`;
			stage.style.opacity = String(Math.max(0.4, 1 - Math.abs(deltaX) / window.innerWidth));
		});

		const handleRelease = () => {
			if (!pointerActive || !stage) return;
			pointerActive = false;

			const threshold = window.innerWidth * 0.2; // 20% width trigger

			if (Math.abs(deltaX) > threshold) {
				navigateToBlock(deltaX < 0 ? 'next' : 'prev');
			} else {
				// Re-center stage canvas if user didn't cross threshold boundaries
				stage.classList.add('animate-physics');
				stage.style.transform = 'translate3d(0, 0, 0)';
				stage.style.opacity = '1';
			}
		};

		window.addEventListener('pointerup', handleRelease);
		window.addEventListener('pointercancel', handleRelease);

		const open = (start = 0) => {
			if (!stage) return;
			stage.classList.remove('animate-physics');
			stage.style.transform = 'translate3d(0, 0, 0)';
			stage.style.opacity = '1';
			index = start;
			showImage(index);
			root.classList.add('open');
			root.setAttribute('aria-hidden', 'false');
		};

		function hide() {
			root.classList.remove('open');
			root.setAttribute('aria-hidden', 'true');
		}

		// Thumbnail clicking continues to swap images within this item's context
		thumbs.forEach((thumb) => {
			thumb.addEventListener('click', () => showImage(Number(thumb.dataset.index)));
		});

		window.addEventListener('keydown', (e) => {
			if (!root.classList.contains('open')) return;
			if (e.key === 'Escape') hide();
			if (e.key === 'ArrowRight') navigateToBlock('next');
			if (e.key === 'ArrowLeft') navigateToBlock('prev');
		});

		window.addEventListener('open-lightbox', (e: Event) => {
			const customEvent = e as CustomEvent;
			if (customEvent.detail && customEvent.detail.id === id) {
				open(customEvent.detail.index ?? 0);
			}
		});
	});
</script>
