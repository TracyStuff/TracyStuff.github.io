---
import { Image } from 'astro:assets';
import type { MediaItem } from '../../lib/data';

interface Props {
	id: string;
	media: MediaItem[];
	title?: string;
	caption?: string;
}

const { id, media, title, caption } = Astro.props;
const images = media ?? [];
---

<div class="lightbox" data-lightbox={id} aria-hidden="true">
	<div class="lightbox-backdrop"></div>
	<div class="lightbox-content">
		<button class="lightbox-close" aria-label="Close">×</button>
		<button class="lightbox-prev" aria-label="Previous image">‹</button>

		<div class="lightbox-image-wrap">
			{title && <div class="lightbox-title">{title}</div>}
			<div class="lightbox-canvas">
				<img class="lightbox-image" alt="" />
			</div>
			{caption && <div class="lightbox-caption-text">{caption}</div>}
		</div>

		<button class="lightbox-next" aria-label="Next image">›</button>

		<div class="lightbox-caption-bar">
			<span class="lightbox-counter"></span>
		</div>

		<div class="lightbox-thumbnails">
			{images.map((image, index) => (
				<button class="lightbox-thumb" data-index={index} aria-label={`Show image ${index + 1}`}>
					<Image
						src={image.src}
						alt={image.alt ?? ''}
						width={100}
						height={100}
						format="webp"
						quality={60}
					/>
				</button>
			))}
		</div>
	</div>
</div>

<style>
.lightbox {
	position: fixed;
	inset: 0;
	z-index: 9999;
	display: none;
	align-items: center;
	justify-content: center;
}
.lightbox.open { display: flex; }
.lightbox-backdrop {
	position: absolute;
	inset: 0;
	background: rgba(0,0,0,.96);
}
.lightbox-content {
	position: relative;
	z-index: 1;
	width: 100%;
	height: 100%;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
}
.lightbox-image-wrap {
	width: 100%;
	height: 65vh;
	display: block;
	text-align: center;
	z-index: 2;
}
.lightbox-title {
	width: 100%;
	text-align: center;
	margin: 0 auto 20px auto;
	padding: 0 20px;
	box-sizing: border-box;
	color: #ffffff;
	font-family: sans-serif;
	font-size: 20px;
	font-weight: 500;
	text-shadow: 0 2px 5px rgba(0,0,0,0.8);
}
.lightbox-canvas {
	width: 100%;
	height: calc(100% - 50px);
	display: flex;
	align-items: center;
	justify-content: center;
}
.lightbox-image {
	max-width: 95%;
	max-height: 100%;
	object-fit: contain;
	border: 3px solid #fff;
	box-shadow: 0 0 25px rgba(0,0,0,0.9);
	transition: opacity 0.25s ease-in-out;
}
.lightbox-caption-text {
	color: #bbb;
	font-size: 14px;
	margin-top: 10px;
}
.lightbox-close {
	position: absolute;
	right: 30px;
	top: 20px;
	font-size: 40px;
	color: white;
	background: none;
	border: 0;
	cursor: pointer;
	z-index: 10000;
}
.lightbox-prev, .lightbox-next {
	position: absolute;
	top: 50%;
	transform: translateY(-50%);
	font-size: 40px;
	background: rgba(255,255,255,0.1);
	border: 0;
	color: white;
	cursor: pointer;
	padding: 5px 15px;
	border-radius: 5px;
	z-index: 10000;
}
.lightbox-prev { left: 30px; }
.lightbox-next { right: 30px; }
.lightbox-caption-bar {
	margin-top: 25px;
	color: white;
}
.lightbox-thumbnails {
	display: flex;
	gap: 8px;
	margin-top: 15px;
	max-width: 800px;
	padding: 0 20px;
	overflow-x: auto;
}
.lightbox-thumb {
	padding: 0;
	border: 2px solid transparent;
	background: none;
	cursor: pointer;
	opacity: 0.5;
	transition: all 0.2s;
}
.lightbox-thumb.active {
	border-color: #159957;
	opacity: 1;
}
.lightbox-thumb img {
	width: 75px;
	height: 75px;
	object-fit: cover;
	border-radius: 4px;
}
</style>

<script>
	const lightboxes = document.querySelectorAll('[data-lightbox]');

	lightboxes.forEach((rootEl) => {
		const root = rootEl as HTMLElement;
		if (root.dataset.initialized) return;
		root.dataset.initialized = 'true';

		const id = root.dataset.lightbox;
		const img = root.querySelector('.lightbox-image') as HTMLImageElement;
		const counter = root.querySelector('.lightbox-counter');
		const thumbs = Array.from(root.querySelectorAll('.lightbox-thumb')) as HTMLElement[];
		const close = root.querySelector('.lightbox-close');
		const next = root.querySelector('.lightbox-prev'); // Left navigation hook
		const prev = root.querySelector('.lightbox-next'); // Right navigation hook

		const clientImages = thumbs.map((thumb) => {
			const thumbImg = thumb.querySelector('img');
			return {
				src: thumbImg ? thumbImg.src : '',
				alt: thumbImg ? thumbImg.alt : ''
			};
		});

		let index = 0;

		const show = (newIndex: number) => {
			if (clientImages.length === 0 || !img) return;

			// Quick transition fade out
			img.style.opacity = '0';

			setTimeout(() => {
				index = (newIndex + clientImages.length) % clientImages.length;
				const item = clientImages[index];

				img.src = item.src;
				img.alt = item.alt;
				img.style.opacity = '1';

				if (counter) {
					counter.textContent = `${index + 1} / ${clientImages.length}`;
				}

				thumbs.forEach((thumb, i) => {
					thumb.classList.toggle('active', i === index);
				});
			}, 150);
		};

		const open = (start = 0) => {
			index = start;
			show(index);
			root.classList.add('open');
			root.setAttribute('aria-hidden', 'false');
		};

		const hide = () => {
			root.classList.remove('open');
			root.setAttribute('aria-hidden', 'true');
		};

		next?.addEventListener('click', () => show(index - 1));
		prev?.addEventListener('click', () => show(index + 1));
		close?.addEventListener('click', hide);
		root.querySelector('.lightbox-backdrop')?.addEventListener('click', hide);

		thumbs.forEach((thumb) => {
			thumb.addEventListener('click', () => {
				show(Number(thumb.dataset.index));
			});
		});

		window.addEventListener('keydown', (e) => {
			if (!root.classList.contains('open')) return;
			if (e.key === 'Escape') hide();
			if (e.key === 'ArrowRight') show(index + 1);
			if (e.key === 'ArrowLeft') show(index - 1);
		});

		window.addEventListener('open-lightbox', (e: Event) => {
			const customEvent = e as CustomEvent;
			if (customEvent.detail && customEvent.detail.id === id) {
				open(customEvent.detail.index ?? 0);
			}
		});
	});
</script>
