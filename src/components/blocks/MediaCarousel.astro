---
import { Image } from 'astro:assets';
import { tinaField } from '@tinacms/astro/tina-field';
import type { MediaItem } from '../../lib/data';

interface Props {
	media: MediaItem[];
}

const { media } = Astro.props;
const images = media ?? [];
---

<div
	class="media-carousel"
	data-total={images.length}
>
	<div class="media-strip">
		{images.map((image) => (
			<div
				class="media-slide"
				data-tina-field={tinaField(image)}
			>
				<Image
					src={image.src}
					alt={image.alt ?? ''}
					width={600}
					height={450}
					format="webp"
					quality={80}
					class="media-image"
				/>
			</div>
		))}
	</div>

	{images.length > 1 && (
		<>
			<button
				class="media-button media-prev"
				aria-label="Previous image"
			>
				‹
			</button>

			<button
				class="media-button media-next"
				aria-label="Next image"
			>
				›
			</button>

			<div class="media-counter">
				<span class="current">1</span>/{images.length}
			</div>
		</>
	)}
</div>


<script>
	document.querySelectorAll<HTMLElement>('.media-carousel')
	.forEach((carousel) => {

		if (carousel.dataset.initialized) return;
		carousel.dataset.initialized = 'true';


		const strip =
			carousel.querySelector<HTMLElement>('.media-strip');

		const slides =
			Array.from(
				carousel.querySelectorAll<HTMLElement>('.media-slide')
			);

		const counter =
			carousel.querySelector<HTMLElement>('.current');

		const prev =
			carousel.querySelector<HTMLButtonElement>('.media-prev');

		const next =
			carousel.querySelector<HTMLButtonElement>('.media-next');


		let index = 0;

		let pointerActive = false;
		let startX = 0;
		let startY = 0;
		let deltaX = 0;


		const update = () => {
			if (!strip) return;

			strip.style.transform =
				`translate3d(-${index * 100}%,0,0)`;

			if (counter) {
				counter.textContent = String(index + 1);
			}
		};


		const setDragPosition = (percent:number) => {
			if (!strip) return;

			strip.style.transform =
				`translate3d(${-index * 100 + percent}%,0,0)`;
		};


		const move = (amount:number) => {
			index += amount;

			if (index < 0) {
				index = slides.length - 1;
			}

			if (index >= slides.length) {
				index = 0;
			}

			strip?.classList.add('animate');

			update();
		};


		prev?.addEventListener('click', (event) => {
			event.stopPropagation();
			move(-1);
		});


		next?.addEventListener('click', (event) => {
			event.stopPropagation();
			move(1);
		});


		carousel.addEventListener('pointerdown', (event) => {

			if ((event.target as HTMLElement).closest('button')) {
				return;
			}

			pointerActive = true;

			startX = event.clientX;
			startY = event.clientY;
			deltaX = 0;

			strip?.classList.remove('animate');

			carousel.setPointerCapture(event.pointerId);
		});


		carousel.addEventListener('pointermove', (event) => {

			if (!pointerActive) return;

			deltaX = event.clientX - startX;

			const deltaY =
				event.clientY - startY;


			// Allow normal vertical scrolling
			if (Math.abs(deltaY) > Math.abs(deltaX)) {
				return;
			}


			const percent =
				(deltaX / carousel.offsetWidth) * 100;


			setDragPosition(percent);
		});


		const release = (event: PointerEvent) => {

			if (!pointerActive) return;

			pointerActive = false;


			try {
				carousel.releasePointerCapture(event.pointerId);
			} catch {}


			const threshold =
				carousel.offsetWidth * 0.15;


			strip?.classList.add('animate');


			if (Math.abs(deltaX) > threshold) {

				if (deltaX < 0) {
					move(1);
				} else {
					move(-1);
				}

			} else {

				update();

			}
		};


		carousel.addEventListener(
			'pointerup',
			release
		);

		carousel.addEventListener(
			'pointercancel',
			release
		);


		update();

	});
</script>


<style>
.media-carousel {
	position: relative;
	width: 100%;
	overflow: hidden;
	border-radius: 0.75rem;
	background: #222;
	touch-action: pan-y;
	user-select: none;
}


.media-strip {
	display: flex;
	width: 100%;
	height: 100%;
	will-change: transform;
}


.media-strip.animate {
	transition:
		transform 0.3s cubic-bezier(.25,1,.5,1);
}


.media-slide {
	flex: 0 0 100%;
	width: 100%;
}


.media-image {
	display: block;
	width: 100%;
	aspect-ratio: 4 / 3;
	object-fit: cover;
	pointer-events: none;
}


.media-button {
	position: absolute;
	top: 50%;
	transform: translateY(-50%);

	width: 36px;
	height: 36px;

	border: none;
	border-radius: 50%;

	background: rgba(0,0,0,.45);
	color: white;

	font-size: 28px;
	line-height: 1;

	cursor: pointer;
	z-index: 5;

	opacity: 0;
	transition: opacity .2s;
}


.media-carousel:hover .media-button {
	opacity: 1;
}


.media-prev {
	left: 12px;
}


.media-next {
	right: 12px;
}


.media-counter {
	position: absolute;
	right: 12px;
	bottom: 12px;

	background: rgba(0,0,0,.7);
	color: white;

	padding: 4px 10px;
	border-radius: 999px;

	font-size: 12px;
	font-weight: bold;

	z-index: 5;
}


@media(max-width:768px) {
	.media-button {
		opacity: 1;
	}
}
</style>
